# 数据库
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/waterdesign

# LLM 配置
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o
LLM_API_KEY=sk-xxx
LLM_BASE_URL=https://api.openai.com/v1
LLM_TEMPERATURE=0.3

# Embedding 配置（留空则回退使用 LLM API Key）
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=

# 通用
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10737418240
MAX_CONTEXT_MESSAGES=10
